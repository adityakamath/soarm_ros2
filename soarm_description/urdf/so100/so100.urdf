<?xml version="1.0" ?>
<robot name="so100">
  <material name="light_grey">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="charcoal">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin rpy="0 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Base.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin rpy="0 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Base_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin rpy="0 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Base.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="shoulder_link">
    <inertial>
      <mass value="0.119226"/>
      <origin rpy="0 0 0" xyz="-9.07886e-05 -0.031089 0.0590972"/>
      <inertia ixx="5.94278e-05" ixy="0" ixz="0" iyy="3.13712e-05" iyz="0" izz="5.89975e-05"/>
    </inertial>
    <visual>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Rotation_Pitch.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Rotation_Pitch_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Rotation_Pitch.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="upper_arm_link">
    <inertial>
      <mass value="0.162409"/>
      <origin rpy="0 0 0" xyz="-0.00310545 0.0701802 -1.72052e-05"/>
      <inertia ixx="7.01522e-05" ixy="0" ixz="0" iyy="0.000167164" iyz="0" izz="0.000213312"/>
    </inertial>
    <visual>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Upper_Arm.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Upper_Arm_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Upper_Arm.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="lower_arm_link">
    <inertial>
      <mass value="0.147968"/>
      <origin rpy="0 0 0" xyz="-0.0768007 0.00137796 -0.00339604"/>
      <inertia ixx="4.84242e-05" ixy="0" ixz="0" iyy="0.000107748" iyz="0" izz="0.000138803"/>
    </inertial>
    <visual>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Lower_Arm.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Lower_Arm_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Lower_Arm.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="wrist_link">
    <inertial>
      <mass value="0.0661321"/>
      <origin rpy="0 0 0" xyz="2.34622e-05 -0.0352279 -0.00852653"/>
      <inertia ixx="1.94704e-05" ixy="0" ixz="0" iyy="2.39041e-05" iyz="0" izz="3.45403e-05"/>
    </inertial>
    <visual>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Wrist_Pitch_Roll.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Wrist_Pitch_Roll_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin rpy="0 -1.5707963268 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Wrist_Pitch_Roll.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_link">
    <inertial>
      <mass value="0.0929859"/>
      <origin rpy="0 0 0" xyz="0.00552377 -0.000483583 -0.0280167"/>
      <inertia ixx="5.03136e-05" ixy="0" ixz="0" iyy="2.72961e-05" iyz="0" izz="4.64098e-05"/>
    </inertial>
    <visual>
      <origin rpy="1.5707963268 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Fixed_Jaw.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin rpy="1.5707963268 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../../meshes/so100/Fixed_Jaw_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
  </link>
  <link name="jaw_link">
    <inertial>
      <mass value="0.0202444"/>
      <origin rpy="0 0 0" xyz="-0.00161745 -0.0303473 0.000449646"/>
      <inertia ixx="1.11265e-05" ixy="0" ixz="0" iyy="8.99651e-06" iyz="0" izz="2.99548e-06"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../../meshes/so100/Moving_Jaw.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
  </link>
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0.0452 0 0.0165"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.942" lower="-2" upper="2" velocity="5.21553467881118"/>
  </joint>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin rpy="-1.5707963268 1.3415926536 0" xyz="0.0306 0 0.1025"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.942" lower="0" upper="3.5" velocity="5.21553467881118"/>
  </joint>
  <joint name="elbow_flex_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <origin rpy="0 0 1.5707963268" xyz="-0.028 0.11257 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.942" lower="-3.14158" upper="0" velocity="5.21553467881118"/>
  </joint>
  <joint name="wrist_flex_joint" type="revolute">
    <parent link="lower_arm_link"/>
    <child link="wrist_link"/>
    <origin rpy="0 0 -1" xyz="-0.1349 0.0052 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.942" lower="-2.5" upper="1.2" velocity="5.21553467881118"/>
  </joint>
  <joint name="wrist_roll_joint" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin rpy="-1.5707963268 0 0" xyz="0 -0.0601 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.942" lower="-3.14158" upper="3.14158" velocity="5.21553467881118"/>
  </joint>
  <joint name="gripper_joint" type="revolute">
    <parent link="gripper_link"/>
    <child link="jaw_link"/>
    <origin rpy="1.5707963268 0 3.1415926536" xyz="-0.0202 0 -0.0244"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.942" lower="-0.2" upper="2.0" velocity="5.21553467881118"/>
  </joint>
  <ros2_control name="so100_control" type="system">
    <hardware>
      <plugin>sts_hardware_interface/STSHardwareInterface</plugin>
      <param name="serial_port">/dev/ttySERVO</param>
      <param name="baud_rate">1000000</param>
      <param name="use_sync_write">True</param>
      <param name="enable_mock_mode">False</param>
    </hardware>
    <joint name="shoulder_pan_joint">
      <param name="motor_id">1</param>
      <param name="operating_mode">0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <joint name="shoulder_lift_joint">
      <param name="motor_id">2</param>
      <param name="operating_mode">0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <joint name="elbow_flex_joint">
      <param name="motor_id">3</param>
      <param name="operating_mode">0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <joint name="wrist_flex_joint">
      <param name="motor_id">4</param>
      <param name="operating_mode">0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <joint name="wrist_roll_joint">
      <param name="motor_id">5</param>
      <param name="operating_mode">0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <joint name="gripper_joint">
      <param name="motor_id">6</param>
      <param name="operating_mode">0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
  </ros2_control>
</robot>
