<?xml version="1.0"?>
<robot name="so100" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find soarm_description)/urdf/so100/so100.common.xacro"/>
  <xacro:include filename="$(find soarm_description)/urdf/so100/so100.control.xacro"/>

  <!-- Arguments (externally settable, default to property values in so100.control.xacro) -->
  <xacro:arg name="serial_port"    default="${serial_port}"/>
  <xacro:arg name="use_mock"       default="${use_mock}"/>
  <xacro:arg name="use_sync_write" default="${use_sync_write}"/>

  <material name="light_grey">
    <color rgba="${light_grey_rgba}"/>
  </material>
  <material name="charcoal">
    <color rgba="${charcoal_rgba}"/>
  </material>

  <!-- LINKS -->

  <!-- Base link -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${base_offset_rz}"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Base.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${base_offset_rz}"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Base_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 ${base_offset_rz}"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Base.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Shoulder link -->
  <link name="shoulder_link">
    <inertial>
      <mass value="0.119226"/>
      <origin xyz="-9.07886e-05 -0.031089 0.0590972" rpy="0 0 0"/>
      <inertia ixx="5.94278e-05" ixy="0" ixz="0" iyy="3.13712e-05" iyz="0" izz="5.89975e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="${shoulder_offset_rx} 0 ${shoulder_offset_rz}"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Rotation_Pitch.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="${shoulder_offset_rx} 0 ${shoulder_offset_rz}"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Rotation_Pitch_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${shoulder_offset_rx} 0 ${shoulder_offset_rz}"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Rotation_Pitch.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Upper arm link -->
  <link name="upper_arm_link">
    <inertial>
      <mass value="0.162409"/>
      <origin xyz="-0.00310545 0.0701802 -1.72052e-05" rpy="0 0 0"/>
      <inertia ixx="7.01522e-05" ixy="0" ixz="0" iyy="0.000167164" iyz="0" izz="0.000213312"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 ${upper_arm_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Upper_Arm.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 ${upper_arm_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Upper_Arm_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 ${upper_arm_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Upper_Arm.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Lower arm link -->
  <link name="lower_arm_link">
    <inertial>
      <mass value="0.147968"/>
      <origin xyz="-0.0768007 0.00137796 -0.00339604" rpy="0 0 0"/>
      <inertia ixx="4.84242e-05" ixy="0" ixz="0" iyy="0.000107748" iyz="0" izz="0.000138803"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 ${lower_arm_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Lower_Arm.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 ${lower_arm_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Lower_Arm_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 ${lower_arm_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Lower_Arm.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Wrist link -->
  <link name="wrist_link">
    <inertial>
      <mass value="0.0661321"/>
      <origin xyz="2.34622e-05 -0.0352279 -0.00852653" rpy="0 0 0"/>
      <inertia ixx="1.94704e-05" ixy="0" ixz="0" iyy="2.39041e-05" iyz="0" izz="3.45403e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 ${wrist_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Wrist_Pitch_Roll.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 ${wrist_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Wrist_Pitch_Roll_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 ${wrist_visual_ry} 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Wrist_Pitch_Roll.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Gripper link (fixed jaw) -->
  <link name="gripper_link">
    <inertial>
      <mass value="0.0929859"/>
      <origin xyz="0.00552377 -0.000483583 -0.0280167" rpy="0 0 0"/>
      <inertia ixx="5.03136e-05" ixy="0" ixz="0" iyy="2.72961e-05" iyz="0" izz="4.64098e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="${gripper_visual_rx} 0 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Fixed_Jaw.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="${gripper_visual_rx} 0 0"/>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Fixed_Jaw_Motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
  </link>

  <!-- Moving jaw link -->
  <link name="jaw_link">
    <inertial>
      <mass value="0.0202444"/>
      <origin xyz="-0.00161745 -0.0303473 0.000449646" rpy="0 0 0"/>
      <inertia ixx="1.11265e-05" ixy="0" ixz="0" iyy="8.99651e-06" iyz="0" izz="2.99548e-06"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://soarm_description/meshes/so100/Moving_Jaw.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
  </link>

  <!-- JOINTS -->

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="${shoulder_pan_xyz}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${shoulder_pan_lower}" upper="${shoulder_pan_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="${shoulder_lift_xyz}" rpy="${shoulder_lift_rpy}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${shoulder_lift_lower}" upper="${shoulder_lift_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <joint name="elbow_flex_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <origin xyz="${elbow_flex_xyz}" rpy="${elbow_flex_rpy}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${elbow_flex_lower}" upper="${elbow_flex_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <joint name="wrist_flex_joint" type="revolute">
    <parent link="lower_arm_link"/>
    <child link="wrist_link"/>
    <origin xyz="${wrist_flex_xyz}" rpy="${wrist_flex_rpy}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${wrist_flex_lower}" upper="${wrist_flex_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <joint name="wrist_roll_joint" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin xyz="${wrist_roll_xyz}" rpy="${wrist_roll_rpy}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${wrist_roll_lower}" upper="${wrist_roll_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <joint name="gripper_joint" type="revolute">
    <parent link="gripper_link"/>
    <child link="jaw_link"/>
    <origin xyz="${gripper_xyz}" rpy="${gripper_rpy}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${gripper_lower}" upper="${gripper_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <!-- ROS 2 CONTROL -->
  <ros2_control name="so100_control" type="system">
    <hardware>
      <plugin>sts_hardware_interface/STSHardwareInterface</plugin>
      <param name="serial_port">$(arg serial_port)</param>
      <param name="baud_rate">${baud_rate}</param>
      <param name="use_sync_write">$(arg use_sync_write)</param>
      <param name="enable_mock_mode">$(arg use_mock)</param>
    </hardware>

    <joint name="shoulder_pan_joint">
      <param name="motor_id">${shoulder_pan_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>

    <joint name="shoulder_lift_joint">
      <param name="motor_id">${shoulder_lift_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>

    <joint name="elbow_flex_joint">
      <param name="motor_id">${elbow_flex_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>

    <joint name="wrist_flex_joint">
      <param name="motor_id">${wrist_flex_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>

    <joint name="wrist_roll_joint">
      <param name="motor_id">${wrist_roll_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>

    <joint name="gripper_joint">
      <param name="motor_id">${gripper_motor_id}</param>
      <param name="operating_mode">${operating_mode}</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
  </ros2_control>

</robot>
